## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you have legacy Eclipse formatter settings
# .settings/

# Visual Studio 2017+ cache/options directory
.idea/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Build Results of an ATL Project
[Dd]ebugPS/
[Rr]eleasePS/
dlldata.c

# Benchmark Results
BenchmarkDotNet.Artifacts/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# StyleCop
StyleCopReport.xml

# Files built by Visual Studio
*_i.c
*_p.c
*_h.h
*.ilk
*.meta
*.obj
*.iobj
*.pch
*.pdb
*.ipdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*_wpftmp.csproj
*.log
*.vspscc
*.vssscc
.builds
*.pidb
*.svclog
*.scc

# Chutzpah Test files
_Chutzpah*

# Visual C++ cache files
ipch/
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb

# Visual F# compiled intermediate files
*.fsi
*.fsp
*.pds

# MSBuild generated files
*.targets
*.props

# Visual Studio trace files
*. IntelliTrace
*.etl

# ClickOnce publish files
publish/

# Publish Web Output
*.[Pp]ublish.xml
*.pubxml
# Note: Using the *.[Pp]ublish.xml pattern would cause the removal of
# the following file: ExampleApplication.Publish.xml
# An alternative which avoids this issue would be:
# *.Publish.xml
# !*.example.Pubxml

# Microsoft Azure Web App publish settings. Comment the next line if you don't want to ignore these files by default.
*.azurePubxml

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if necessary however generally it will be regenerated when needed
#!NuGet.exe
# Un-comment and modify the next line to ensure that NuGet can be found when you don't have (Package Restore) for this solution enabled.
# !**/NuGet.Config

# Microsoft Azure Build Output
csx/
*.build.csdef

# Microsoft Azure Emulator
ecf/
rcf/

# Windows Store app package directory built with MSBuild
AppPackages/
BundleArtifacts/
Package.StoreAssociation.xml
_pkginfo.txt

# Visual Studio cache/options/Temporary project files
# Directory.Build.props
# Directory.Build.targets
*_temporarykey.pfx

# Local History for Visual Studio
.localhistory/

# Database Project Temp
*.mdblogs

# Speedo
.spd

# Phoenix Unit Tests
testResults.json

# Backups
*.bak
*.tmp
*.cache

# Machine-specific settings file
appsettings.Development.json
appsettings.Production.json
connectionStrings.json

# Environment specific files
.env
.env.local
.env.production
.env.test