// Toàn bộ routing sẽ được cấu hình tại đây
{
  "Jwt": {
    "Key": "your-super-secret-key-at-least-32-chars",
    "Issuer": "HouseLink.Identity",
    "Audience": "HouseLink.API"
  },
  "ReverseProxy": {
    "Routes": {
      "listing-route": {
        "ClusterId": "listing-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/api/listings/{**catch-all}" }
      },
      "listing-public-route": {
        "ClusterId": "listing-cluster",
        "Match": { "Path": "/api/listings/public/{**catch-all}" },
        "AuthorizationPolicy": "allow_all"
      },
      "core-route": {
        "ClusterId": "core-cluster",
        "Match": { "Path": "/{**catch-all}" },
        "AuthorizationPolicy": "allow_all"
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/api/notifications/{**catch-all}" }
      },
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" },
        "AuthorizationPolicy": "allow_all"
      }
    },
    "Clusters": {
      "listing-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "listing-1": { "Address": "http://localhost:5001" }
        }
      },
      "core-cluster": {
        "Destinations": {
          "search-1": { "Address": "http://10.0.0.13:5002/v1" }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification-1": { "Address": "http://localhost:5005" }
        }
      },
      "identity-cluster": {
        "Destinations": {
          "identity-1": { "Address": "http://localhost:5006" }
        }
      }
    }
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      },
      {
        "Endpoint": "post:/api/auth/login",
        "Period": "5m",
        "Limit": 10
      }
    ]
  }
}
